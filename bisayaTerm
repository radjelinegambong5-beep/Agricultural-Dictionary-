 /*
This method is used to check if the user input contains special characters 
and tells the program if the input is invalid.

*/
public static boolean hasSpecialChars(String input) {
    return !input.matches("[a-zA-Z ]+");
}


/*
  Chloe Jane M. Montañez
  This method used to fix the user input by removing spaces and correcting the letters.
*/

public String normalizeInput(String input) {
    input = input.trim().toLowerCase();

    if (input.isEmpty()) {
        return input;
    }

    return input.substring(0, 1).toUpperCase() + input.substring(1);
}

