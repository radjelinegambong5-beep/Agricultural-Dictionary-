public void runProgram() {
        Scanner sc = new Scanner(System.in);
        loadData();

        System.out.println("Bisaya Agriculture Dictionary");
        System.out.println("Type 'exit' to quit.");

        while (true) {
            System.out.print("Ibutang ang term: ");
            String input = sc.nextLine().trim();

            if (input.equalsIgnoreCase("exit")) {
                System.out.println("Salamat sa paggamit sa dictionary! Bye!");
                break;
            }

            boolean found = false;

            for (int i = 0; i < count; i++) {
                if (data[i] != null) {
                    String[] parts = data[i].split(":", 2);
                    if (parts[0].equalsIgnoreCase(input)) {
                        System.out.println(parts[1].trim());
                        found = true;
                        break;
                    }
                }
            }

            if (!found) {
                System.out.println("Wala pa na dria nabutang bay.,. Salamat ha!");
            }
        }

        sc.close();
    }

